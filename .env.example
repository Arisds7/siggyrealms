# ─── Supabase ──────────────────────────────────────────────────────────────────
# Ambil dari Project Settings > API di dashboard Supabase kamu
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ─── Ritual Testnet ────────────────────────────────────────────────────────────
# Cek RPC resmi terbaru di https://docs.ritual.net
NEXT_PUBLIC_RITUAL_RPC_URL=https://rpc.ritualfoundation.org
NEXT_PUBLIC_CHAIN_ID=1979

# ─── GenesisEgg Contract ───────────────────────────────────────────────────────
# Address contract GenesisEgg yang sudah di-deploy ke Ritual Testnet
# Deploy address Bagian 1: 0xf2d016B3d8E7e415feccF377981a4EB51F2C829C
NEXT_PUBLIC_GENESIS_EGG_ADDRESS=0xf2d016B3d8E7e415feccF377981a4EB51F2C829C

# ─── Cron Secret ───────────────────────────────────────────────────────────────
# Digunakan untuk mengamankan endpoint cron (/api/cron/energy-regen) agar tidak di-spam.
# Untuk local development, kamu bisa mengisinya sembarang string atau samakan dengan server.
# Cara generate secure random string (di terminal run): openssl rand -base64 32
CRON_SECRET=isi_dengan_random_string_di_sini

